#include <iostream>
using namespace std;

class A {
    int x;
public:
    void set(int a) { x = a; }
    friend class B;
};

class B {
public:
    void show(A a) {
        cout << a.x << endl;
    }
};

int main() {
    A a;
    B b;

    int x;
    cin >> x;

    a.set(x);
    b.show(a);

    return 0;
}
