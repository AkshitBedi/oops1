#include <iostream>
using namespace std;

class Complex {
    int real, imag;
public:
    Complex(int r, int i) {
        real = r;
        imag = i;
    }

    Complex(const Complex &c) {
        real = c.real;
        imag = c.imag;
    }

    void display() {
        cout << real << " " << imag << endl;
    }

    friend Complex sum(Complex, Complex);
};

Complex sum(Complex c1, Complex c2) {
    return Complex(c1.real + c2.real, c1.imag + c2.imag);
}

int main() {
    int r1, i1, r2, i2;
    cin >> r1 >> i1 >> r2 >> i2;

    Complex c1(r1, i1), c2(r2, i2);
    Complex c3 = sum(c1, c2);

    c3.display();

    return 0;
}
