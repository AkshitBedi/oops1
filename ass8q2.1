#include <iostream>
using namespace std;

template <class T>
class Stack {
    T arr[100];
    int top;
public:
    Stack(){ top=-1; }

    void push(T x){
        arr[++top] = x;
    }

    void pop(){
        if(top>=0) top--;
    }

    void display(){
        for(int i=top;i>=0;i--) cout<<arr[i]<<" ";
    }
};

int main(){
    Stack<int> s;
    int n,x;
    cin>>n;
    for(int i=0;i<n;i++){
        cin>>x;
        s.push(x);
    }
    s.pop();
    s.display();
    return 0;
}
