#include <iostream>
using namespace std;

class Base {
protected:
    int x;
public:
    void set(int a) {
        x = a;
    }
};

class Derived : public Base {
public:
    void show() {
        cout << x << endl;
    }
};

int main() {
    Derived d;
    int val;
    cin >> val;

    d.set(val);
    d.show();

    return 0;
}
