#include <iostream>
#include <cmath>
using namespace std;

float area(float b, float h) {
    return 0.5 * b * h;
}

float area(float a) {
    return (sqrt(3)/4) * a * a;
}

float area(float a, float b, float c) {
    float s = (a+b+c)/2;
    return sqrt(s*(s-a)*(s-b)*(s-c));
}

int main() {
    float a, b, c;
    cin >> a >> b >> c;

    cout << area(a, b) << endl;
    cout << area(a) << endl;
    cout << area(a, b, c) << endl;

    return 0;
}
