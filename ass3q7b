#include <iostream>
using namespace std;

class Demo {
    int x;
public:
    void set(int a) { x = a; }
    void show() { cout << x << endl; }

    Demo add(Demo &d) {
        Demo temp;
        temp.x = x + d.x;
        return temp;
    }
};

int main() {
    Demo d1, d2, d3;
    int a, b;
    cin >> a >> b;

    d1.set(a);
    d2.set(b);

    d3 = d1.add(d2);
    d3.show();

    return 0;
}
