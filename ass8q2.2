#include <iostream>
using namespace std;

template <class T>
class Queue {
    T arr[100];
    int front,rear;
public:
    Queue(){ front=0; rear=-1; }

    void enqueue(T x){
        arr[++rear] = x;
    }

    void dequeue(){
        if(front<=rear) front++;
    }

    void display(){
        for(int i=front;i<=rear;i++) cout<<arr[i]<<" ";
    }
};

int main(){
    Queue<int> q;
    int n,x;
    cin>>n;
    for(int i=0;i<n;i++){
        cin>>x;
        q.enqueue(x);
    }
    q.dequeue();
    q.display();
    return 0;
}
