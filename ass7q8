#include <iostream>
using namespace std;

class Array {
    int a[5];
public:
    int& operator[](int i){
        if(i<0 || i>=5){
            cout<<"Out of bounds"<<endl;
            exit(0);
        }
        return a[i];
    }
};

int main(){
    Array arr;
    for(int i=0;i<5;i++) cin>>arr[i];
    for(int i=0;i<5;i++) cout<<arr[i]<<" ";
    return 0;
}
