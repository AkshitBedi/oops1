#include <iostream>
using namespace std;

class Person {
protected:
    string name, address;
public:
    void setPerson(string n, string a) {
        name = n;
        address = a;
    }
};

class Staff : virtual public Person {
protected:
    string employee_id, department;
public:
    void setStaff(string n, string a, string id, string dept) {
        setPerson(n, a);
        employee_id = id;
        department = dept;
    }
};

class Student : virtual public Person {
protected:
    string student_id, grade;
public:
    void setStudent(string n, string a, string id, string g) {
        setPerson(n, a);
        student_id = id;
        grade = g;
    }
};

class TeachingAssistant : public Staff, public Student {
public:
    void setTA(string n, string a, string eid, string dept, string sid, string g) {
        setPerson(n, a);
        employee_id = eid;
        department = dept;
        student_id = sid;
        grade = g;
    }
    void show() {
        cout << name << endl;
        cout << address << endl;
        cout << employee_id << endl;
        cout << department << endl;
        cout << student_id << endl;
        cout << grade << endl;
    }
};

int main() {
    string n, a, eid, dept, sid, g;
    cin >> n >> a >> eid >> dept >> sid >> g;

    TeachingAssistant ta;
    ta.setTA(n, a, eid, dept, sid, g);
    ta.show();

    return 0;
}
